
_GIT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | cut -d'/' -f3)

_ADDONS=""

if [ ! -z "$_GIT_BRANCH" ]; then
	_ADDONS="$_ADDONS"" %F{015}on %F{001} $_GIT_BRANCH"
fi

if [ -n "$HOST" ] && [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
	PROMPT="%F{004}%n %F{015}@ %F{002}$HOST:%~$_ADDONS%F{015}$ "	
else
	PROMPT="%F{004}%n %F{015}@ %F{002}%~$_ADDONS%F{015}$ "	
fi
